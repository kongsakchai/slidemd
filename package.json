{
	"name": "core",
	"version": "1.0.0",
	"type": "module",
	"main": "index.js",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"cli": "npm run build:parse && npm run build:slidemd && npm run dev -w @slidemd/cli",
		"dev": "npm run build:parse && npm run build:slidemd && npm run dev -w @slidemd/dev",
		"build":"npm run build:parse && npm run build:slidemd",
		"build:parse":"npm run test -w @slidemd/parse",
		"build:slidemd":"npm run test -w @slidemd/parse",
		"prettier": "prettier --write .",
		"test":"npm run test:parse && npm run test:slidemd",
		"test:parse": "npm run test -w @slidemd/parse",
		"test:slidemd": "npm run test -w @slidemd/slidemd"
	},
	"keywords": [],
