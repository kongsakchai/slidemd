	"devDependencies": {
		"@sveltejs/package": "^2.5.7",
		"@trivago/prettier-plugin-sort-imports": "^6.0.2",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^4.1.4",
		"prettier": "^3.8.2",
		"tsdown": "^0.21.9",
		"typescript": "^5.9.3",
		"vitest": "^4.1.4"
	}
}
