{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ESNext",
		"lib": ["ESNext", "DOM"],
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"declaration": true,
		"strict": true,
		"strictNullChecks": true,
		"esModuleInterop": true,
		"skipDefaultLibCheck": true,
		"skipLibCheck": true,
		"paths": {
			"@slidemd/parse/*": ["./packages/parse/*"],
			"@slidemd/slidemd/*": ["./packages/slidemd/src/*"]
		}
	},
	"include": ["./packages/**/*.ts", "./packages/**/*.d.ts", "./packages/**/*.svelte"]
}
