{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ESNext",
		"lib": ["ESNext", "DOM"],
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"declaration": true,
		"strict": true,
		"strictNullChecks": true,
		"esModuleInterop": true,
		"skipDefaultLibCheck": true,
		"skipLibCheck": true,
		"paths": {
			"@slidemd/parse": ["./packages/parse"],
			"@slidemd/cli": ["./packages/cli"],
			"@slidemd/slidemd": ["./packages/slidemd"]
		}
	},
	"include": ["./packages/**/*.ts", "./packages/**/*.d.ts"]
}
