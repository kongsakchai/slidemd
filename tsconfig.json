{
	"compilerOptions": {
		"module": "esnext",
		"target": "esnext",
		"lib": ["esnext", "DOM"],
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"declaration": true,
		"strict": true,
		"strictNullChecks": true,
		"esModuleInterop": true,
		"skipDefaultLibCheck": true,
		"skipLibCheck": true,
		"paths": {
			"@slidemd/core": ["./packages/src/index.ts"]
		}
	},
	"include": ["./packages/**/*.ts", "./packages/**/*.d.ts"]
}
