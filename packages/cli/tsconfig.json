{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "src",
		"types": ["node", "svelte"],
		"paths": {
			"@/*": ["./src/*"],
			"@command": ["./src/command"],
			"@templates": ["./src/templates"],
			"@html": ["./src/html"],
			"@contents": ["./src/contents"]
		}
	},
	"include": ["./src/**/*.ts", "./src/**/*.d.ts", "./src/**/*.svelte"]
}
